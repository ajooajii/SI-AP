rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      let email = (request.auth != null && request.auth.token != null && request.auth.token.email != null ? request.auth.token.email : "").lower();
      let isInternal = email.endsWith('ritase.dlh') || email == 'bpsdlh@gmail.com';
      let verified = request.auth != null && request.auth.token != null && request.auth.token.email_verified == true;
      
      // Fallback: if user doc exists, they are considered verified for our app logic
      let hasProfile = request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      
      return isSignedIn() && (verified || isInternal || hasProfile);
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user is admin or co-admin
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && request.auth.token.email != null && request.auth.token.email in ['bpsdlh@gmail.com', 'bpsdlh@ritase.dlh']) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isCoAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'co-admin';
    }

    function isAdminOrCoAdmin() {
      return isAdmin() || isCoAdmin();
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Functions ---

    function isValidUser(data) {
      let requiredFields = ['userId', 'username', 'email', 'role', 'account_name', 'status'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string && data.userId.size() > 0 &&
             data.username is string && data.username.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'co-admin', 'user', 'viewer', 'operator_bakung'] &&
             data.account_name is string && data.account_name.size() > 0 &&
             data.status in ['active', 'inactive', 'pending', 'rejected'] &&
             (!('operator_name' in data) || data.operator_name is string) &&
             (!('assigned_upt_id' in data) || data.assigned_upt_id is string || data.assigned_upt_id == null) &&
             (!('assigned_upt_name' in data) || data.assigned_upt_name is string || data.assigned_upt_name == null);
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['date', 'vehiclePlate', 'driverName', 'upt', 'tpa', 'tonnage', 'volume', 'tripCount', 'createdBy', 'timestamp']) &&
             data.date is string &&
             data.vehiclePlate is string && data.vehiclePlate.size() <= 20 &&
             data.driverName is string && data.driverName.size() <= 100 &&
             data.upt is string &&
             data.tpa is string &&
             (data.tonnage is number || data.tonnage is int) &&
             (data.volume is number || data.volume is int) &&
             data.tripCount is int &&
             data.createdBy == request.auth.uid &&
             (data.timestamp == request.time || data.timestamp == existing().timestamp);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['mainTpaId', 'isTpaLocked']) &&
             data.mainTpaId is string &&
             data.isTpaLocked is bool;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminOrCoAdmin());
      allow list: if isSignedIn() && isAdminOrCoAdmin();
      
      // Allow a user to create their own initial profile document with role viewer and status pending,
      // OR allow the master admin bpsdlh@gmail.com to create their active admin profile document.
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
                      (incoming().role == 'viewer' && incoming().status == 'pending') ||
                      (incoming().email.lower() == 'bpsdlh@gmail.com') ||
                      (request.auth.token != null && request.auth.token.email != null && request.auth.token.email.lower() == 'bpsdlh@gmail.com')
                    );
      
      // Allow user themselves to update non-privileged fields, or admin to change anything.
      allow update: if isSignedIn() && (
                      isAdminOrCoAdmin() && isValidUser(incoming())
                    ) || (
                      request.auth.uid == userId && isValidUser(incoming()) &&
                      incoming().role == existing().role &&
                      incoming().status == existing().status
                    );
                    
      allow delete: if isSignedIn() && isAdmin();
    }

    match /upts/{uptId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /tpas/{tpaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /tps/{tpsId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdminOrCoAdmin() && isValidSettings(incoming());
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn() && isAdminOrCoAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidTrip(incoming()) && (
        isAdminOrCoAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == 'user' &&
         getUserData().status == 'active' &&
         (incoming().upt == getUserData().assigned_upt_name ||
          incoming().created_by_upt_name == getUserData().assigned_upt_name))
      );
      
      allow update: if isSignedIn() && isAdminOrCoAdmin() && isValidTrip(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['tonnage', 'volume', 'tripCount', 'updatedAt', 'syncAt', 'updatedBy', 'timestamp', 'upt', 'tpa', 'driverName', 'vehiclePlate', 'date', 'operationalTime'])
      );
                    
      allow delete: if isSignedIn() && isAdminOrCoAdmin();
    }

    match /data_sampah_bakung/{recordId} {
      allow create: if isSignedIn() && (
                      isAdminOrCoAdmin() ||
                      (
                        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                        getUserData().role == 'operator_bakung' &&
                        incoming().created_by_uid == request.auth.uid
                      )
                    );
                    
      allow read: if isSignedIn();
                   
      allow update, delete: if isSignedIn() && isAdminOrCoAdmin();
    }
  }
}
